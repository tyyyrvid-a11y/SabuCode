# Copy this file to .env and fill in your values.

# NVIDIA NIM (https://build.nvidia.com) - OpenAI-compatible endpoint
NVIDIA_NIM_API_KEY=nvapi-REPLACE_WITH_YOUR_KEY
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=z-ai/glm-5.2
NVIDIA_NIM_MAX_TOKENS=16384

PORT=3000
NODE_ENV=development
RATE_LIMIT_PER_MINUTE=60

# Supabase (https://supabase.com) - cloud sync for chat sessions, schema in supabase/schema.sql
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY
